# Copia este archivo a .env.local y rellena los valores cuando actives
# cada integración. Ninguna es necesaria para que la web funcione hoy —
# esta es una propuesta de diseño, todavía sin conectar a servicios reales.

# NovaCore Reserve — motor de reservas. Sustituye la lógica de
# src/lib/reservations.ts. NovaCore Reserve es también el punto desde el
# que se orquestarían el bot de WhatsApp con IA, las confirmaciones
# automáticas, los recordatorios y el futuro panel privado del restaurante.
NOVACORE_RESERVE_URL=
NOVACORE_RESERVE_API_KEY=

# Reseñas de Google (Places API), para la sección "Opiniones"
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
