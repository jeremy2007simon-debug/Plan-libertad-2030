# Copia este archivo a .env.local y rellena los valores cuando actives
# cada integración. Ninguna es necesaria para que la web funcione hoy.

# Dominio real del sitio, para metadata/OG/sitemap/robots. Sin esta
# variable, se usa http://localhost:3000 (ver src/lib/site.ts) — nunca un
# dominio de ejemplo inventado.
NEXT_PUBLIC_SITE_URL=

# Base de datos de reservas (futuro). Hoy las reservas se guardan en
# memoria (src/lib/reservations/store.ts); ver el esquema de referencia
# en db/schema.sql.
DATABASE_URL=

# Notificación por correo al restaurante cuando entra una reserva
# (src/lib/reservations/notify.ts). Sin esta variable, no se envía nada.
RESERVATION_NOTIFICATION_EMAIL=

# NovaCore Reserve — motor de reservas. Sustituye la lógica de
# src/lib/reservations/index.ts. NovaCore Reserve es también el punto
# desde el que se orquestarían el bot de WhatsApp con IA, las
# confirmaciones automáticas, los recordatorios y el futuro panel privado
# del restaurante.
NOVACORE_RESERVE_URL=
NOVACORE_RESERVE_API_KEY=

# Reseñas de Google (Places API), para la sección "Opiniones". Sin esta
# clave, la sección muestra la valoración de Tripadvisor (ver
# src/lib/constants.ts → AGGREGATE_REVIEWS).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
